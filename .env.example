# ===== 应用配置 =====
APP_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS 允许的前端地址（逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_UPLOAD=20/minute

# ===== Redis 配置 =====
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_ENABLED=true

# ===== MySQL 配置 =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=rag_system

# ===== ChromaDB 配置 =====
CHROMA_PERSIST_DIR=./chroma_db

# ===== 文件上传配置 =====
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=png,jpg,jpeg,gif,bmp,webp

# 语音识别为可选功能；启用后还需安装 requirements-voice.txt 和 ffmpeg
VOICE_ENABLED=false
MAX_AUDIO_SIZE_MB=30
ALLOWED_AUDIO_TYPES=mp3,wav,m4a,aac,ogg,wma,flac,pcm

# ===== Embedding 配置 =====
# local | openai
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== 大模型配置 =====
# openai | deepseek | ollama | qianfan | dashscope
DEFAULT_LLM_PROVIDER=openai

# OpenAI / DeepSeek (兼容 OpenAI 接口)
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# 通义千问
DASHSCOPE_API_KEY=sk-xxxx
DASHSCOPE_MODEL=qwen-max

# 文心一言
QIANFAN_ACCESS_KEY=xxxx
QIANFAN_SECRET_KEY=xxxx
QIANFAN_MODEL=ERNIE-4.0-8K

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ===== 检索配置 =====
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.3
VECTOR_WEIGHT=0.7
BM25_WEIGHT=0.3

# 重排序（Cross-Encoder 精排）
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_MULTIPLIER=4
RERANK_TOP_K=5

# ===== 分块配置 =====
CHUNK_SIZE=512
CHUNK_OVERLAP=50
